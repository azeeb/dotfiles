#!/bin/bash

# VoiceInk Update Checker & Installer
# Usage: voiceink-update

CONFIG_FILE="$HOME/.config/voiceink-update.conf"

# shellcheck source=voiceink-update.conf
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Config file not found. Copy voiceink-update.conf.example to $CONFIG_FILE and set your paths."
    exit 1
fi
source "$CONFIG_FILE"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${CYAN}║       VoiceInk Update Checker        ║${RESET}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════╝${RESET}"
echo ""

# Check that the VoiceInk directory exists
if [ ! -d "$VOICEINK_DIR" ]; then
    echo -e "${RED}Error: VoiceInk directory not found at $VOICEINK_DIR${RESET}"
    echo "Please check VOICEINK_DIR in $CONFIG_FILE."
    exit 1
fi

cd "$VOICEINK_DIR" || exit 1

# Fetch latest changes from remote without applying them
echo -e "${YELLOW}Checking for updates...${RESET}"
git fetch origin main --quiet

# Compare local HEAD with remote
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main)

if [ "$LOCAL" = "$REMOTE" ]; then
    echo -e "${GREEN}✓ VoiceInk is already up to date!${RESET}"
    echo ""
    exit 0
fi

# There are updates — show what's new
echo -e "${YELLOW}Updates are available!${RESET}"
echo ""
echo -e "${BOLD}What's new since your last build:${RESET}"
echo -e "${CYAN}──────────────────────────────────────────${RESET}"
git log HEAD..origin/main --pretty=format:"  %C(yellow)%h%Creset  %C(bold)%s%Creset%n         %C(dim)%ar by %an%Creset" --no-merges
echo ""
echo -e "${CYAN}──────────────────────────────────────────${RESET}"

# Count number of commits
COMMIT_COUNT=$(git log HEAD..origin/main --oneline --no-merges | wc -l | tr -d ' ')
echo ""
echo -e "${BOLD}$COMMIT_COUNT new commit(s) available.${RESET}"
echo ""

# Ask user
read -r -p "$(echo -e "${BOLD}Would you like to install the updates? (yes/no): ${RESET}")" ANSWER
echo ""

case "$ANSWER" in
    yes|y|YES|Y)
        echo -e "${YELLOW}Pulling latest changes...${RESET}"
        git pull origin main

        echo ""
        echo -e "${YELLOW}Building VoiceInk... (this may take a few minutes)${RESET}"
        echo ""

        make local

        if [ $? -eq 0 ]; then
            # Move updated app to Applications
            echo ""
            echo -e "${YELLOW}Installing updated app to /Applications...${RESET}"
            cp -R "$VOICEINK_BUILD_OUTPUT" "$VOICEINK_INSTALL_DIR"
            echo -e "${GREEN}✓ VoiceInk has been updated and installed successfully!${RESET}"
        else
            echo -e "${RED}Build failed. Please check the errors above.${RESET}"
            exit 1
        fi
        ;;
    no|n|NO|N)
        echo -e "Update skipped. Run ${CYAN}voiceink-update${RESET} anytime to check again."
        ;;
    *)
        echo -e "${RED}Invalid input. Please type 'yes' or 'no'.${RESET}"
        exit 1
        ;;
esac

echo ""
